# OBS Events — client environment (copy to .env). Vite exposes only VITE_* vars.
VITE_API_URL=http://localhost:4000/api/v1
# Google sign-in — must match the server GOOGLE_CLIENT_ID. Leave empty to hide the Google button.
VITE_GOOGLE_CLIENT_ID=
# Stripe publishable key (pk_...) — public by design.
VITE_STRIPE_PUBLISHABLE_KEY=
# Google Maps browser key — restrict by HTTP referrer in Google Cloud, and use a
# SEPARATE key from the server GOOGLE_MAPS_API_KEY (don't share one across both).
VITE_GOOGLE_MAPS_API_KEY=
